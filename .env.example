# ─── Application ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string (Neon or Supabase)
# Format: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ─── Auth.js (NextAuth v5) ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — create at https://console.cloud.google.com/
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email magic-link provider (e.g. Resend)
# Sign up at https://resend.com and create an API key
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=noreply@yourdomain.com

# ─── AI — Google Gemini ────────────────────────────────────────────
# Create at https://aistudio.google.com/app/apikey
# NEVER expose this to the client (used only in server routes)
GEMINI_API_KEY=

# ─── Strava OAuth ─────────────────────────────────────────────────
# Create app at https://www.strava.com/settings/api
# Authorized callback: http://localhost:3000/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ─── Fitness data aggregator (Terra / Vital / Spike) ──────────────
# Set up later — leave blank for MVP
# Choose provider based on your device coverage needs (see INTEGRATIONS.md)
AGGREGATOR_API_KEY=
AGGREGATOR_WEBHOOK_SECRET=
AGGREGATOR_BASE_URL=

# ─── Token encryption ──────────────────────────────────────────────
# AES-256 key for encrypting OAuth tokens at rest in the DB
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
